# WARNING: Use a dedicated hot wallet with limited funds. Never use your main wallet.
# WARNING: Never commit this file to git.

# Required: choose exactly one trading-key input.
# Local CLI/dev only:
# PRIVATE_KEY=0xyour_private_key_here
# PRIVATE_KEY_FILE=./secrets/trading.key
# KEYSTORE_PATH=./secrets/trading.keystore.json
# KEYSTORE_PASSWORD_FILE=./secrets/trading.keystore.password
# Optional local-dev fallback for keystore decryption:
# Docker Compose does not forward KEYSTORE_PASSWORD into the container.
# KEYSTORE_PASSWORD=your_keystore_password

# Pricing provider credentials:
# - COINGECKO_API_KEY or COINGECKO_API_KEY_FILE is required for pricing.provider = "coingecko" or "hybrid"
# - COINGECKO_API_PLAN is optional: auto (default), demo, or pro
# - ALCHEMY_API_KEY or ALCHEMY_API_KEY_FILE is required for pricing.provider = "alchemy" or "hybrid"
# - If RPC_PROVIDER=alchemy and RPC_API_KEY or RPC_API_KEY_FILE is set, it is reused for Alchemy pricing automatically
# Local CLI/dev:
# COINGECKO_API_KEY=your_coingecko_api_key
# Safer local or Docker:
# COINGECKO_API_KEY_FILE=./secrets/coingecko.key
# COINGECKO_API_PLAN=auto
# ALCHEMY_API_KEY=your_alchemy_price_api_key
# ALCHEMY_API_KEY_FILE=./secrets/alchemy.key

# RPC provider: set these two and RPC URLs are auto-constructed for all chains.
# Supported providers: alchemy, infura
RPC_PROVIDER=alchemy
# RPC_API_KEY=your_alchemy_or_infura_api_key
# RPC_API_KEY_FILE=./secrets/rpc-provider.key

# Flashbots auth signing key for Mainnet bundles.
# Recommended: persist this separately so relay reputation survives restarts.
# Local CLI/dev only:
# FLASHBOTS_AUTH_KEY=0xyour_flashbots_auth_key_here
# FLASHBOTS_AUTH_KEY_FILE=./secrets/flashbots-auth.key

# Optional: RPC URL used by the mainnet fork smoke test.
MAINNET_RPC_URL=

# Optional Docker/runtime override for the /health listener port.
# The app, Compose port mapping, and Docker healthcheck all follow this value.
# HEALTH_CHECK_PORT=8080

# Optional deploy helpers for the FlashArbExecutor deploy script.
# The wrapper now fills AJNA token plus family-specific Uniswap router/factory
# defaults for the built-in chains. Set these only to override a preset or to
# deploy against a custom chain.
# DEPLOY_CHAIN=mainnet
# DEPLOY_RPC_URL=
# FLASH_ARB_EXECUTOR_KIND=v3v3
# FLASH_ARB_EXECUTOR_AJNA_TOKEN=
# FLASH_ARB_EXECUTOR_SWAP_ROUTER=
# FLASH_ARB_EXECUTOR_UNISWAP_V2_FACTORY=
# FLASH_ARB_EXECUTOR_UNISWAP_V3_FACTORY=
# FLASH_ARB_EXECUTOR_UNISWAP_V3_POOL_INIT_CODE_HASH=
