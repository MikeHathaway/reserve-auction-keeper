# WARNING: Use a dedicated hot wallet with limited funds. Never use your main wallet.
# WARNING: Never commit this file to git.

# Required: Wallet private key (must start with 0x)
PRIVATE_KEY=0xyour_private_key_here

# Required: Coingecko Pro API key
COINGECKO_API_KEY=your_coingecko_api_key

# RPC URLs (can also be set in config.json)
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_key
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/your_key

# Private RPC URLs for MEV protection (optional, recommended)
MAINNET_PRIVATE_RPC_URL=
BASE_PRIVATE_RPC_URL=

# Flashbots auth signing key for Mainnet bundles (optional, generated if missing)
FLASHBOTS_AUTH_KEY=
