# WARNING: Use a dedicated hot wallet with limited funds. Never use your main wallet.
# WARNING: Never commit this file to git.

# Required: Wallet private key (must start with 0x)
PRIVATE_KEY=0xyour_private_key_here

# Required: Coingecko Pro API key
COINGECKO_API_KEY=your_coingecko_api_key

# RPC provider: set these two and RPC URLs are auto-constructed for all chains.
# Supported providers: alchemy, infura
RPC_PROVIDER=alchemy
RPC_API_KEY=your_alchemy_or_infura_api_key

# Flashbots auth signing key for Mainnet bundles (optional, auto-generated if missing)
FLASHBOTS_AUTH_KEY=
