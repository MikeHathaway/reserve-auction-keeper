{
  "name": "reserve-auction-keeper",
  "version": "0.1.0",
  "description": "Ajna Reserve Auction Keeper — monitors and participates in Ajna protocol reserve auctions",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "preanalytics:executions": "npm run build",
    "analytics:executions": "node scripts/analyze-executions.mjs",
    "build": "tsc",
    "deploy:flash-arb-executor": "node scripts/deploy-flash-arb-executor.mjs",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:integration:mainnet": "vitest run --config vitest.integration.config.ts",
    "test:contracts": "node scripts/run-contract-tests.mjs",
    "test:contracts:fork:base": "node scripts/run-base-fork-tests.mjs",
    "test:contracts:fork:mainnet": "node scripts/run-mainnet-fork-tests.mjs",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ajna",
    "defi",
    "keeper",
    "reserve-auction",
    "ethereum",
    "base"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.3.1",
    "viem": "^2.47.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.1",
    "@types/node": "^25.5.0",
    "eslint": "^8.57.1",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^2.1.9"
  }
}
